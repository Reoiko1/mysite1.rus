#: src/plugin.php
msgid "Pause the scan? You can resume it later."
msgstr "Pausar el escaneo? Puede reanudarlo mas tarde."

#: src/plugin.php
msgid "Stop the scan completely? You will not be able to resume — only start a new scan."
msgstr "Detener el escaneo completamente? No podra reanudarlo — solo iniciar un nuevo escaneo."

#: src/plugin.php
msgid "Are you sure you want to restart from the beginning? Already checked links will be skipped (cached)."
msgstr "Esta seguro de que desea reiniciar desde el principio? Los enlaces ya verificados se omitiran (en cache)."

#: src/plugin.php
msgid "Are you sure you want to clear all data? This cannot be undone."
msgstr "Esta seguro de que desea borrar todos los datos? Esta accion no se puede deshacer."

#: src/plugin.php
