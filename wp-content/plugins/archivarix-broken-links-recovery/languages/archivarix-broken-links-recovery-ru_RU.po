msgid "No links found."
msgstr "Ссылки не найдены."

#: 21
msgid "No logs yet."
msgstr "Логов пока нет."

#: 22
msgid "Copied!"
msgstr "Скопировано!"

#: 23
msgid "Extracting links"
msgstr "Извлечение ссылок"

#: 24
msgid "Checking links"
msgstr "Проверка ссылок"

#: 25
msgid "links found"
msgstr "ссылок найдено"

#: 26
msgid "Links"
msgstr "Ссылки"

#: 27
msgid "Checked"
msgstr "Проверено"

#: 28
msgid "Broken"
msgstr "Битые"

#: 29
msgid "internal"
msgstr "внутренние"

#: 30
msgid "Items to scan"
msgstr "Элементов для сканирования"

#: 31
msgid "Pending links"
msgstr "Ожидающие ссылки"

#: 32
msgid "View"
msgstr "Просмотр"

#: 33
msgid "Search"
msgstr "Поиск"

#: 34
msgid "Open archived version in Web Archive"
msgstr "Открыть архивную версию в Web Archive"

#: 35
msgid "Search for this URL in Web Archive"
msgstr "Найти этот URL в Web Archive"

#: 36
msgid "Not applicable for internal links"
msgstr "Не применимо для внутренних ссылок"

#: 37
msgid "Internal link checking is not enabled. Go to Settings tab and enable \"Check internal links for 404 errors\", then run a new scan."
msgstr "Проверка внутренних ссылок не включена. Перейдите на вкладку «Настройки» и включите «Проверять внутренние ссылки на ошибки 404», затем запустите новое сканирование."

#: 38
msgid "If found in Web Archive — replace broken link with archive copy. If not found — remove the link tag but keep the anchor text visible."
msgstr "Если найдено в Web Archive — заменить битую ссылку архивной копией. Если не найдено — удалить тег ссылки, но сохранить текст привязки видимым."

#: 39
msgid "If found in Web Archive — replace broken link with archive copy. If not found — remove both the link tag and its anchor text completely."
msgstr "Если найдено в Web Archive — заменить битую ссылку архивной копией. Если не найдено — полностью удалить тег ссылки и текст привязки."

#: 40
msgid "Do not check Web Archive. Immediately remove the link tag but keep the anchor text visible. Faster processing — saves 1-3 seconds per broken link."
msgstr "Не проверять Web Archive. Сразу удалить тег ссылки, но сохранить текст привязки видимым. Быстрая обработка — экономит 1-3 секунды на каждую битую ссылку."

#: 41
msgid "Do not check Web Archive. Immediately remove both the link tag and its anchor text completely. Faster processing — saves 1-3 seconds per broken link."
msgstr "Не проверять Web Archive. Сразу полностью удалить тег ссылки и текст привязки. Быстрая обработка — экономит 1-3 секунды на каждую битую ссылку."

